# ── Server ─────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
WORKERS=2
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ── Database ───────────────────────────────────────────────────
DATABASE_PATH=./ai_market.db

# ── Data Refresh ───────────────────────────────────────────────
REFRESH_INTERVAL_MINUTES=60
NEWS_FEEDS=https://techcrunch.com/category/artificial-intelligence/feed/,https://openai.com/news/rss.xml,https://blog.google/technology/ai/rss/,https://feeds.bloomberg.com/technology/news.rss,https://export.arxiv.org/rss/cs.AI

# ── Stock Universe ─────────────────────────────────────────────
# UNIVERSE_SOURCE:
#   top_performers — S&P 500 subset (rotates daily), ranked by Finnhub quote % change (needs FINNHUB_*).
#   dynamic_llm    — LLM picks from built-in industry lists + headlines (needs LLM_ENABLED).
#   static         — only DEFAULT_TICKERS below.
#   watchlist      — only WATCHLIST_TICKERS (for radar/ticker without changing alert list layout).
#   tracked        — only TRACKED_TICKERS (separate list; good when watchlist ≠ what you want scored).
#   blend          — watchlist ∪ TRACKED_TICKERS (else DEFAULT_TICKERS), then fill with top_performers
#                    up to DYNAMIC_UNIVERSE_SIZE (needs FINNHUB_* for movers).
UNIVERSE_SOURCE=top_performers
TOP_PERFORMER_POOL_MAX=100
TOP_PERFORMER_MIN_PRICE=2.0
# Used as fallback if movers/LLM fail, and as the full list when UNIVERSE_SOURCE=static
DEFAULT_TICKERS=SPY,QQQ,NVDA,MSFT
DYNAMIC_UNIVERSE_ENABLED=true
DYNAMIC_UNIVERSE_SIZE=15
DYNAMIC_UNIVERSE_EXPLORE_MODE=true
DYNAMIC_UNIVERSE_BLEND_FALLBACK=false
DYNAMIC_UNIVERSE_MIN_FRESH=3

# ── Scoring ────────────────────────────────────────────────────
SUMMARY_CONFIDENCE_THRESHOLD=0.35
RECOMMENDATION_CONFIDENCE_THRESHOLD=0.45
SCORING_MODEL_VERSION=scoring-v1.1

# ── Watchlist & Alerts ─────────────────────────────────────────
WATCHLIST_TICKERS=NVDA,MSFT,GOOGL
# When UNIVERSE_SOURCE=tracked, comma-separated symbols for scoring/radar only (optional).
TRACKED_TICKERS=
ALERT_SCORE_THRESHOLD=0.55
ALERT_SENTIMENT_THRESHOLD=0.35
ALERT_DELTA_THRESHOLD=0.08

# ── LLM (OpenAI-compatible) ───────────────────────────────────
LLM_ENABLED=false
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini
LLM_BASE_URL=https://api.openai.com/v1
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=500
LLM_SUMMARY_MAX_ARTICLES=8

# ── External APIs (optional) ──────────────────────────────────
NEWSAPI_ENABLED=false
NEWSAPI_API_KEY=
# Recommended ON for top_performers universe (quote endpoint).
FINNHUB_ENABLED=false
FINNHUB_API_KEY=
